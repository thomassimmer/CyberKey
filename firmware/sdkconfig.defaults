# BLE via NimBLE (Classic BT disabled to save RAM)
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_CONTROLLER_ONLY=n
CONFIG_BT_NIMBLE_MAX_CONNECTIONS=3
CONFIG_BTDM_CTRL_BLE_MAX_CONN=3

# Persist bond keys (LTK + IRK) across power cycles.
# Without this, NimBLE uses a RAM-only store: the bond is lost on every reboot,
# which prevents macOS from reconnecting automatically.
CONFIG_BT_NIMBLE_NVS_PERSIST=y

# Stack sizes
CONFIG_BT_NIMBLE_HOST_TASK_STACK_SIZE=16384
CONFIG_FREERTOS_HZ=1000
CONFIG_ESP_MAIN_TASK_STACK_SIZE=16384

CONFIG_PM_ENABLE=y
CONFIG_FREERTOS_USE_TICKLESS_IDLE=y
CONFIG_PM_DFS_INIT_AUTO=y
# Allow NimBLE to maintain the BLE link during light sleep using the 32 kHz
# sleep clock.  Without this, any active BLE connection blocks light sleep
# entirely, making CONFIG_PM_ENABLE effectively a no-op while connected.
CONFIG_BT_NIMBLE_RUN_BLE_ON_SUSPEND=y

# BLE controller modem sleep: the radio powers down between connection events
# instead of staying active.  ORIG mode uses an internal RC oscillator for
# wakeup timing, which requires no external crystal and is suitable for the
# M5StickC Plus 2 hardware.  This can save 10-20 mA while BLE is connected.
CONFIG_BT_CTRL_MODEM_SLEEP=y
CONFIG_BT_CTRL_MODEM_SLEEP_MODE_1=y

# PM profiling: enables esp_pm_dump_locks() which logs every active PM lock.
# Use this to identify what is preventing light sleep.
CONFIG_PM_PROFILING=y

# Single-core mode: disable APP_CPU (Core 1) and run everything on PRO_CPU (Core 0).
# On ESP32, automatic light sleep via FreeRTOS tickless idle is only supported in
# single-core mode.  In dual-core mode both cores must be simultaneously idle, which
# never happens in practice with BLE and UART driver tasks — so light sleep never
# fires despite being configured.  Unicore also saves ~10-15 mA by powering off
# the second core entirely.
CONFIG_FREERTOS_UNICORE=y
